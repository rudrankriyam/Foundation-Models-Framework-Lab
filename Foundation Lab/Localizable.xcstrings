          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "创建下一个 LanguageModelSession 并附上准备好的笔录,然后发出附有答复限度的提示。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "建立下一個 LanguageModelSession 帶上已準備好的筆錄 然后發送回覆限量的急件"
          }
        }
      }
    },
