    "SpotlightSearchTool searches content already indexed by your app. Index useful metadata and keep the index synchronized as content changes." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SpotlightSearchTool searches content already indexed by your app. Index useful metadata and keep the index synchronized as content changes."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SpotlightSearchTool Suchen Sie Inhalte, die bereits von Ihrer App indiziert wurden. Indexieren Sie nützliche Metadaten und halten Sie den Index synchronisiert, wenn sich der Inhalt ändert."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SpotlightSearchTool busca contenido ya indexado por tu app. Indice metadatos útiles y mantén el índice sincronizado como cambios de contenido."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SpotlightSearchTool recherche du contenu déjà indexé par votre application. Indexer les métadonnées utiles et garder l'index synchronisé au fur et à mesure que le contenu change."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SpotlightSearchTool ricerca contenuti già indicizzati dalla tua app. Indice metadati utili e mantenere l'indice sincronizzato come modifiche di contenuto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SpotlightSearchTool アプリが既にインデックス化したコンテンツを検索します。 有用なメタデータをインデックス化し、インデックスをコンテンツ変更として同期させる。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SpotlightSearchTool 검색 내용이 이미 앱에 의해 색인. Index 유용한 메타데이터를 저장하고, 인덱스가 콘텐츠 변경으로 동기화됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SpotlightSearchTool Pesquisa conteúdo já indexado pelo seu aplicativo. Indice metadados úteis e mantenha o índice sincronizado com as mudanças de conteúdo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SpotlightSearchTool 搜索您应用程序已经索引的内容 。 索引有用的元数据,并在内容变化时保持索引同步."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SpotlightSearchTool 搜尋您的應用程式已索引內容 。 索引有用的中繼資料, 并在內容變更時保持索引同步 。"
          }
        }
      }
    },
