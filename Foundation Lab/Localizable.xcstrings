    "Foundation Lab can’t write to the adapter folder at %@. Choose another folder." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Foundation Lab kann nicht in den Adapterordner unter %@ schreiben. Wählen Sie einen anderen Ordner."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Foundation Lab can’t write to the adapter folder at %@. Choose another folder."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Foundation Lab no puede escribir en la carpeta del adaptador en %@. Elija otra carpeta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Foundation Lab ne peut pas écrire dans le dossier de l'adaptateur sur %@. Choisissez un autre dossier."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Foundation Lab non può scrivere nella cartella dell'adattatore su %@. Scegli un'altra cartella."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Foundation Lab は、%@ のアダプター フォルダーに書き込むことができません。別のフォルダーを選択してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Foundation Lab는 %@의 어댑터 폴더에 쓸 수 없습니다. 다른 폴더를 선택하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Foundation Lab não pode gravar na pasta do adaptador em %@. Escolha outra pasta."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Foundation Lab 无法写入位于 %@ 的适配器文件夹。选择另一个文件夹。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Foundation Lab 無法寫入位於 %@ 的適配器資料夾。選擇另一個資料夾。"
          }
        }
      }
    },
    "Foundation Lab could not keep access to the selected bridge folder." : {
