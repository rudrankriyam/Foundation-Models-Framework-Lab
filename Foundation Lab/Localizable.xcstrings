    "Reduce the response reserve, compact more history, or start a fresh session." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reduce the response reserve, compact more history, or start a fresh session."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reduzieren Sie die Antwortreserve, kompaktieren Sie mehr Geschichte oder starten Sie eine neue Sitzung."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reducir la reserva de respuesta, compactar más historia o iniciar una sesión nueva."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Réduire la réserve de réponse, compacter plus d'historique, ou commencer une nouvelle session."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ridurre la riserva di risposta, compatta più storia, o avviare una sessione fresca."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "応答予約を削減し、より多くの履歴をコンパクト化したり、新鮮なセッションを開始する。"
          }
        },
        "ko" : {
          "stringUnit" : {
