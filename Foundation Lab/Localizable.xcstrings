          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Foundation Lab copias importadas .fmadapter paquetes en soporte de aplicaciones para que permanezcan disponibles en los lanzamientos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
