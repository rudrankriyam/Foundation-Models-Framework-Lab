    "Dynamic guidance lets the model combine keyword, semantic, date, and content-type queries." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durch die dynamische Führung kann das Modell Schlüsselwort-, Semantik-, Datums- und Inhaltstypabfragen kombinieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dynamic guidance lets the model combine keyword, semantic, date, and content-type queries."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La guía dinámica permite que el modelo combine consultas de palabras clave, semánticas, de fecha y de tipo de contenido."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le guidage dynamique permet au modèle de combiner des requêtes par mot-clé, sémantique, date et type de contenu."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La guida dinamica consente al modello di combinare query su parole chiave, semantica, data e tipo di contenuto."
