        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisez l'outil sélectionné pour l'information actuelle. Demandez confirmation avant de créer ou de changer quoi que ce soit, et n'inventez jamais les résultats manquants."
          }
        },
        "it" : {
