          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今天早上我感觉很分散,但是静静的散步帮助我专注于重要的工作."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
