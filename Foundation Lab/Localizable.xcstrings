        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use a ferramenta selecionada para informações atuais. Peça confirmação antes de criar ou mudar qualquer coisa, e nunca invente resultados perdidos."
