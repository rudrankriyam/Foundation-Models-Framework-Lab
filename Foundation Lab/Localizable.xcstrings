    "Ask about health data available on this device. Answers are informational and are not medical advice." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ask about health data available on this device. Answers are informational and are not medical advice."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fragen Sie nach Gesundheitsdaten, die auf diesem Gerät verfügbar sind. Antworten sind informativ und sind kein medizinischer Rat."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pregunte sobre los datos de salud disponibles en este dispositivo. Las respuestas son informativos y no son consejos médicos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
