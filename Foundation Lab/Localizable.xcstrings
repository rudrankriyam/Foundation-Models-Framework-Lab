        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilizzare prosa vivida ma economica, non più di 350 parole, e terminare su un'immagine non risolta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
