        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "動的ガイダンスにより、モデルはキーワード、セマンティック、日付、コンテンツ タイプのクエリを組み合わせることができます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "동적 안내를 통해 모델은 키워드, 의미, 날짜 및 콘텐츠 유형 쿼리를 결합할 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A orientação dinâmica permite que o modelo combine consultas de palavras-chave, semânticas, datas e tipo de conteúdo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "动态指导使模型能够结合关键字、语义、日期和内容类型查询。"
