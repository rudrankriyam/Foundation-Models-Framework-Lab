        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A sessão está ficando quente. Considere resumir curvas antigas antes de adicionar grandes esquemas ou saída de ferramentas."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
