        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "user-visible result가 캡처되면 stale tool-call chatter를 제거하십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retirar conversa fiada quando o resultado visível do usuário for capturado."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一旦捕获到用户可见的结果, 就删除 stale 工具调用聊天 。"
