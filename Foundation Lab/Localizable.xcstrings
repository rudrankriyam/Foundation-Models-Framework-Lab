    "How can I help you today? Ask me about your health data, get personalized tips,\nor set new wellness goals!" : {
      "comment" : "A message displayed below the user's health metrics.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wie kann ich Ihnen heute helfen? Fragen Sie mich nach Ihren Gesundheitsdaten, erhalten Sie personalisierte Tipps,\noder setzen Sie sich neue Wellness-Ziele!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How can I help you today? Ask me about your health data, get personalized tips,\nor set new wellness goals!"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Cómo puedo ayudarte hoy? Pregúntame sobre tus datos de salud, recibe consejos personalizados,\no define nuevas metas de bienestar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comment puis-je vous aider aujourd’hui ? Demandez-moi des informations sur vos données de santé, obtenez des conseils personnalisés,\nou définissez de nouveaux objectifs de bien-être !"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Come posso aiutarti oggi? Chiedimi dei tuoi dati sulla salute, ricevi consigli personalizzati,\no imposta nuovi obiettivi di benessere!"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今日はどのようにお手伝いできますか？健康データについて質問したり、あなたに合ったアドバイスを受けたり、\n新しいウェルネス目標を設定したりできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "오늘은 무엇을 도와드릴까요? 건강 데이터에 대해 물어보거나, 개인 맞춤형 팁을 받아보거나,\n새로운 웰니스 목표를 설정해 보세요!"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Como posso ajudar você hoje? Pergunte sobre seus dados de saúde, receba dicas personalizadas,\nou defina novas metas de bem-estar!"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今天我能为你做什么？你可以向我咨询你的健康数据，获取个性化建议，\n或设定新的健康目标！"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今天我可以如何協助你？可以詢問你的健康數據、獲得個人化建議，\n或設定新的健康目標！"
          }
        }
      }
    },
