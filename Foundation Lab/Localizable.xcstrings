        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Executar ferramentas.ImageInputProbe/image_input_probe.py com termos esperados conhecidos para medir o transporte e a correção semântica no sistema operacional atual e construir modelo."
          }
        },
        "zh-Hans" : {
